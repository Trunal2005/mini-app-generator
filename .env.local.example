# =============================================================================
# AppForge — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL (or any PostgreSQL connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-change-this"

# Set to your domain in production
NEXTAUTH_URL="http://localhost:3000"

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers -> OAuth Apps
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
